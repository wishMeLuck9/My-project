  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ShadowNPC
  npcName: SHADOW_ALLY
  lines:
  - "\u041A \u0432\u043E\u0440\u043E\u0442\u0430\u043C \u0432\u0435\u0434\u0435\u0442
    \u0443\u043B\u0438\u0446\u0430, \u043D\u043E \u0432\u044B\u0431\u043E\u0440 \u0438\u0434\u0435\u0442
    \u0440\u044F\u0434\u043E\u043C \u0441 \u0442\u043E\u0431\u043E\u0439."
  hasChoices: 0
  reactsToNightPath: 1
  peacefulLine: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u0435 \u0438\u0437 \u0441\u043C\u0435\u0440\u0442\u0438. \u0421\u043E\u0445\u0440\u0430\u043D\u0438
    \u044D\u0442\u043E \u0434\u043E \u0432\u043E\u0440\u043E\u0442."
  violentLine: "\u0412\u0440\u0430\u0442\u0430 \u0443\u0437\u043D\u0430\u044E\u0442,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043D\u0435\u0439 \u0442\u044B
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043B\u0435\u0436\u0430\u0442\u044C."
