  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ShadowNPC
  npcName: SHADOW_AFRAID
  lines:
  - "\u041D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438 \u0440\u0435\u0437\u043A\u043E.
    \u042F \u0432\u0441\u0435 \u0435\u0449\u0435 \u043F\u044B\u0442\u0430\u044E\u0441\u044C
    \u0432\u0441\u0442\u0430\u0442\u044C."
  hasChoices: 0
  reactsToNightPath: 1
  peacefulLine: "\u0422\u044B \u043D\u0435 \u0443\u0434\u0430\u0440\u0438\u043B.
    \u0417\u043D\u0430\u0447\u0438\u0442, \u0437\u0434\u0435\u0441\u044C \u0435\u0449\u0435
    \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0434\u043D\u044F\u0442\u044C\u0441\u044F."
  violentLine: "\u042F \u0432\u0438\u0434\u0435\u043B, \u0447\u0442\u043E \u0442\u044B
    \u0441\u0434\u0435\u043B\u0430\u043B. \u041D\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u0439
    \u044D\u0442\u043E \u0432\u044B\u0445\u043E\u0434\u043E\u043C."
