    portuguese: SLOT 1 - AUTOGUARDAR
  - key: save.manual_slot
    russian: "\u0421\u041B\u041E\u0422 {0} - \u0420\u0423\u0427\u041D\u041E\u0415
      \u0421\u041E\u0425\u0420\u0410\u041D\u0415\u041D\u0418\u0415"
    english: SLOT {0} - MANUAL SAVE
    portuguese: SLOT {0} - GUARDAR MANUAL
