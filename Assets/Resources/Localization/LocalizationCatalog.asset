  m_Script: {fileID: 11500000, guid: d8ab4296a0231d74aac7f155b076a754, type: 3}
  m_Name: LocalizationCatalog
  m_EditorClassIdentifier: Assembly-CSharp::LocalizationCatalog
  entries:
  - key: app.title
    russian: VIRUS9
    english: VIRUS9
    portuguese: VIRUS9
  - key: menu.start
    russian: "\u041D\u0410\u0427\u0410\u0422\u042C"
    english: START
    portuguese: INICIAR
  - key: menu.intro
    russian: "\u041C\u0418\u0420 \u0414\u0423\u0428 \u041D\u0415 \u0414\u0410\u0415\u0422
      \u0418\u041D\u0421\u0422\u0420\u0423\u041A\u0426\u0418\u0419.\n\u041D\u041E
      \u0421\u0418\u0421\u0422\u0415\u041C\u0410 \u0417\u0410\u041F\u0418\u0421\u042B\u0412\u0410\u0415\u0422
      \u041A\u0410\u0416\u0414\u042B\u0419 \u0422\u0412\u041E\u0419 \u0428\u0410\u0413."
    english: 'THE WORLD OF SOULS GIVES NO INSTRUCTIONS.

      BUT THE SYSTEM RECORDS
      EVERY STEP YOU TAKE.'
    portuguese: "O MUNDO DAS ALMAS N\xC3O D\xC1 INSTRU\xC7\xD5ES.\nMAS O SISTEMA
      REGISTA CADA PASSO TEU."
  - key: menu.continue_intro
    russian: "\u041F\u0420\u041E\u0414\u041E\u041B\u0416\u0418\u0422\u042C"
    english: CONTINUE
    portuguese: CONTINUAR
  - key: intro.gameplay.1
    russian: "ANTBORN // \u0437\u043E\u043D\u0430 \u0434\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F.\n\u0417\u0434\u0435\u0441\u044C
      \u0442\u0435\u043D\u0438 \u0436\u0434\u0443\u0442, \u043F\u043E\u043A\u0430
      \u043C\u0438\u0440 \u043F\u0440\u0438\u0437\u043D\u0430\u0435\u0442 \u0438\u0445
      \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435."
    english: 'ANTBORN // pre-birth zone.

      Shadows wait here until the world
      recognizes them.'
    portuguese: 'ANTBORN // zona antes do nascimento.

      As sombras esperam aqui
      ate o mundo as reconhecer.'
  - key: intro.gameplay.2
    russian: "\u0422\u044B \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043A\u0430\u043A
      \u043E\u0448\u0438\u0431\u043A\u0430: \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F
      \u0434\u043E\u0431\u0440\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430 \u0434\u0443\u0448\u043E\u0439,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0430
      \u043D\u0435 \u0443\u043C\u0435\u0435\u0442 \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C."
    english: 'You appeared as an error: a small kindness became a soul the system
      cannot record.'
    portuguese: 'Apareceste como um erro: uma pequena bondade tornou-se uma alma
      que o sistema nao consegue registar.'
  - key: intro.gameplay.3
    russian: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u043D\u0435 \u0437\u043B\u0438\u0442\u0441\u044F.
      \u041E\u043D\u0430 \u0441\u0432\u0435\u0440\u044F\u0435\u0442 \u043F\u0440\u0430\u0432\u0438\u043B\u0430.
      \u0414\u043B\u044F \u043D\u0435\u0435 \u0442\u044B \u0437\u0430\u043F\u0438\u0441\u044C
      \u0431\u0435\u0437 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u044F
      \u043D\u0430 \u0436\u0438\u0437\u043D\u044C."
    english: The System is not angry. It checks the rules. To it, you are a record
      without permission to live.
    portuguese: O Sistema nao esta zangado. Verifica as regras. Para ele, es um registo
      sem permissao para viver.
  - key: intro.gameplay.4
    russian: "\u0418\u0434\u0438 \u043A \u0441\u0432\u0435\u0442\u0443. \u0421\u043E\u0431\u0435\u0440\u0438
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442. \u041A\u043E\u0433\u0434\u0430
      \u0412\u0440\u0430\u0442\u0430 \u043F\u043E\u044F\u0432\u044F\u0442\u0441\u044F,
      \u043E\u043D\u0438 \u043F\u043E\u043F\u0440\u043E\u0441\u044F\u0442 \u0446\u0435\u043D\u0443."
    english: Follow the light. Take the fragment. When the Gate appears, it will
      ask for a price.
    portuguese: Segue a luz. Apanha o fragmento. Quando os Portoes aparecerem, vao
      pedir um preco.
  - key: intro.gameplay.5
    russian: "\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0441\u0442\u043E\u0435:
      \u0434\u0432\u0438\u0433\u0430\u0439\u0441\u044F, \u043F\u0440\u044B\u0433\u0430\u0439,
      \u043A\u0430\u0440\u0430\u0431\u043A\u0430\u0439\u0441\u044F \u0440\u044F\u0434\u043E\u043C
      \u0441 \u043A\u0440\u0430\u0435\u043C \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0439
      \u0447\u0435\u0440\u0435\u0437 E."
    english: 'The rules are simple: move, jump, climb near edges, and interact with
      E.'
    portuguese: 'As regras sao simples: move-te, salta, trepa junto a beiras e interage
      com E.'
  - key: menu.new_game
    russian: "\u041D\u041E\u0412\u0410\u042F \u0418\u0413\u0420\u0410"
    english: NEW GAME
    portuguese: NOVO JOGO
