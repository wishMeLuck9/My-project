    russian: "\u041F\u0423\u0421\u0422\u041E"
    english: EMPTY
    portuguese: VAZIO
  - key: hud.interact
    russian: "[E] \u0412\u0417\u0410\u0418\u041C\u041E\u0414\u0415\u0419\u0421\u0422\u0412\u041E\u0412\u0410\u0422\u042C"
    english: '[E] INTERACT'
    portuguese: '[E] INTERAGIR'
  - key: hud.controls.day
    russian: "[WASD] \u0411\u0415\u0413\n[SHIFT] \u0425\u041E\u0414\u042C\u0411\u0410\n[SPACE]
      \u041F\u0420\u042B\u0416\u041E\u041A\n[E] \u0412\u0417\u0410\u0418\u041C\u041E\u0414\u0415\u0419\u0421\u0422\u0412\u0418\u0415\n[ESC]
      \u041F\u0410\u0423\u0417\u0410"
    english: '[WASD] RUN

      [SHIFT] WALK

      [SPACE] JUMP

      [E] INTERACT

      [ESC]
      PAUSE'
    portuguese: '[WASD] CORRER

      [SHIFT] ANDAR

      [SPACE] SALTAR

      [E]
      INTERAGIR

      [ESC] PAUSA'
  - key: hud.controls.night
    russian: "[WASD] \u0411\u0415\u0413\n[SHIFT] \u0425\u041E\u0414\u042C\u0411\u0410\n[SPACE]
      \u041F\u0420\u042B\u0416\u041E\u041A\n[E] \u0412\u0417\u0410\u0418\u041C\u041E\u0414\u0415\u0419\u0421\u0422\u0412\u0418\u0415\n[LMB]
      \u0410\u0422\u0410\u041A\u0410\n[ESC] \u041F\u0410\u0423\u0417\u0410"
    english: '[WASD] RUN

      [SHIFT] WALK

      [SPACE] JUMP

      [E] INTERACT

      [LMB]
      ATTACK

      [ESC] PAUSE'
    portuguese: '[WASD] CORRER

      [SHIFT] ANDAR

      [SPACE] SALTAR

      [E]
      INTERAGIR

      [LMB] ATACAR

      [ESC] PAUSA'
  - key: hud.objective.exterior.fragment
    russian: "SYSTEM // \u0426\u0415\u041B\u042C: \u041D\u0410\u0419\u0414\u0418
      \u0424\u0420\u0410\u0413\u041C\u0415\u041D\u0422 \u0421\u0412\u0415\u0422\u0410"
    english: 'SYSTEM // OBJECTIVE: FIND THE LIGHT FRAGMENT'
    portuguese: 'SYSTEM // OBJETIVO: ENCONTRA O FRAGMENTO DE LUZ'
  - key: hud.objective.exterior.gate
    russian: "SYSTEM // \u0426\u0415\u041B\u042C: \u0414\u041E\u0411\u0415\u0420\u0418\u0421\u042C
      \u0414\u041E \u0414\u0412\u0415\u0420\u0418 \u041A\u0412\u0410\u0414\u0420\u0410\u0422\u0410"
    english: 'SYSTEM // OBJECTIVE: REACH THE SQUARE GATE'
    portuguese: 'SYSTEM // OBJETIVO: CHEGA A PORTA DO QUADRADO'
  - key: hud.objective.night.choice
    russian: "SYSTEM // \u0426\u0415\u041B\u042C: \u041D\u0410\u0411\u041B\u042E\u0414\u0410\u0419
      \u0418\u041B\u0418 \u0414\u0415\u0419\u0421\u0422\u0412\u0423\u0419"
    english: 'SYSTEM // OBJECTIVE: OBSERVE OR ACT'
    portuguese: 'SYSTEM // OBJETIVO: OBSERVA OU AGE'
  - key: hud.objective.night.exit
    russian: "SYSTEM // \u0426\u0415\u041B\u042C: \u0414\u041E\u0411\u0415\u0420\u0418\u0421\u042C
      \u0414\u041E \u0412\u042B\u0425\u041E\u0414\u0410"
    english: 'SYSTEM // OBJECTIVE: REACH THE EXIT'
    portuguese: 'SYSTEM // OBJETIVO: CHEGA A SAIDA'
  - key: hud.objective.final
    russian: "SYSTEM // \u0426\u0415\u041B\u042C: \u0414\u041E\u0419\u0414\u0418
      \u0414\u041E \u0412\u0420\u0410\u0422"
    english: 'SYSTEM // OBJECTIVE: REACH THE GATE'
    portuguese: 'SYSTEM // OBJETIVO: CHEGA AOS PORTOES'
  - key: hud.stability
    russian: "\u0423\u0421\u0422\u041E\u0419\u0427\u0418\u0412\u041E\u0421\u0422\u042C 
      {0}"
    english: STABILITY  {0}
    portuguese: ESTABILIDADE  {0}
  - key: hud.night_unlocked
    russian: "\u041D\u041E\u0427\u042C \u041F\u0420\u0418\u0417\u041D\u0410\u041B\u0410
      \u0412 \u0422\u0415\u0411\u0415 \u0421\u0418\u041B\u0423. \u0423\u0414\u0410\u0420
      \u0414\u041E\u0421\u0422\u0423\u041F\u0415\u041D."
    english: THE NIGHT RECOGNIZED YOUR STRENGTH. ATTACK IS AVAILABLE.
    portuguese: A NOITE RECONHECEU A TUA FORCA. O ATAQUE ESTA DISPONIVEL.
  - key: hud.map_active
    russian: "SYSTEM // \u041A\u0410\u0420\u0422\u0410 \u041A\u0412\u0410\u0414\u0420\u0410\u0422\u0410
      \u0410\u041A\u0422\u0418\u0412\u041D\u0410. \u0412\u042B\u0425\u041E\u0414
      \u041E\u0422\u041C\u0415\u0427\u0415\u041D \u0413\u041E\u041B\u0423\u0411\u042B\u041C."
    english: SYSTEM // SQUARE MAP ACTIVE. EXIT MARKED IN BLUE.
    portuguese: SYSTEM // MAPA DO QUADRADO ATIVO. SAIDA MARCADA A AZUL.
  - key: hud.idle_hint
    russian: "\u0415\u0421\u041B\u0418 \u0422\u042B \u041D\u0415 \u0412\u0417\u0410\u0418\u041C\u041E\u0414\u0415\u0419\u0421\u0422\u0412\u0423\u0415\u0428\u042C,
      \u0422\u042B \u0418\u0421\u0427\u0415\u0417\u0410\u0415\u0428\u042C."
    english: IF YOU DO NOT INTERACT, YOU DISAPPEAR.
    portuguese: SE NAO INTERAGIRES, DESAPARECES.
  - key: hud.start.1
    russian: "\u041F\u0420\u041E\u0422\u041E\u041A\u041E\u041B \u041A\u0412\u0410\u0414\u0420\u0410\u0422\u0410
      \u0410\u041A\u0422\u0418\u0412\u0415\u041D."
    english: SQUARE PROTOCOL ACTIVE.
    portuguese: PROTOCOLO DO QUADRADO ATIVO.
  - key: hud.start.2
    russian: "\u0424\u0420\u0410\u0413\u041C\u0415\u041D\u0422 \u041E\u0411\u041D\u0410\u0420\u0423\u0416\u0415\u041D."
    english: FRAGMENT DETECTED.
    portuguese: FRAGMENTO DETETADO.
  - key: hud.start.3
    russian: "\u0422\u042B \u041D\u0410\u0423\u0427\u0418\u041B\u0421\u042F \u0418\u0414\u0422\u0418.
      \u042D\u0422\u041E\u0413\u041E \u0414\u041E\u0421\u0422\u0410\u0422\u041E\u0427\u041D\u041E,
      \u0427\u0422\u041E\u0411\u042B \u041D\u0410\u0427\u0410\u0422\u042C.\n\u0412\u042B\u0416\u0418\u0412\u0415\u0428\u042C
      \u041B\u0418 \u0422\u042B \u2014 \u0417\u0410\u0412\u0418\u0421\u0418\u0422
      \u041E\u0422 \u0422\u0415\u0411\u042F."
    english: 'YOU HAVE LEARNED TO WALK. THAT IS ENOUGH TO BEGIN.

      WHETHER YOU
      SURVIVE IS UP TO YOU.'
    portuguese: 'APRENDESTE A ANDAR. ISSO BASTA PARA COMECAR.

      SOBREVIVER DEPENDE
      DE TI.'
  - key: hud.health
    russian: "\u0416\u0418\u0417\u041D\u042C {0}/{1}"
    english: HP {0}/{1}
    portuguese: VIDA {0}/{1}
  - key: hud.boss
    russian: "\u0421\u0422\u0420\u0410\u0416\u0418 {0}%"
    english: GUARDIANS {0}%
    portuguese: GUARDIOES {0}%
  - key: hud.boss.phase2
    russian: "\u0421\u0422\u0420\u0410\u0416\u0418 {0}%  \u0424\u0410\u0417\u0410
      2"
    english: GUARDIANS {0}%  PHASE 2
    portuguese: GUARDIOES {0}%  FASE 2
  - key: hud.damage
    russian: "\u0421\u0442\u0440\u0430\u0436 \u043F\u043E\u043F\u0430\u043B. \u0423\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C
      {0}/{1}"
    english: Guardian hit. Stability {0}/{1}
    portuguese: O guardiao acertou. Estabilidade {0}/{1}
  - key: hud.exterior.stability_lost
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u0432\u044B\u043F\u0430\u043B
      \u0438\u0437 \u0442\u0435\u0431\u044F. \u041F\u0435\u0440\u0432\u044B\u0439
      \u043A\u0432\u0430\u0434\u0440\u0430\u0442 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442
      \u0442\u0435\u0431\u044F \u043A \u0441\u0442\u0430\u0440\u0442\u0443."
    english: The fragment falls out of you. The first square returns you to the start.
    portuguese: O fragmento cai de ti. O primeiro quadrado devolve-te ao inicio.
  - key: hud.exterior.retry_keep_fragment
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
      \u0441 \u0442\u043E\u0431\u043E\u0439. \u041F\u0435\u0440\u0432\u044B\u0439
      \u043A\u0432\u0430\u0434\u0440\u0430\u0442 \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442
      \u0442\u0435\u0431\u044F \u043D\u0430\u0437\u0430\u0434."
    english: The fragment stays with you. The first square throws you back.
    portuguese: O fragmento fica contigo. O primeiro quadrado atira-te para tras.
  - key: boss.intro
    russian: "\u0421\u0442\u0440\u0430\u0436\u0438 \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0438\u0441\u044C.
      \u0412\u044B\u0436\u0438\u0432\u0438 \u0432 \u0441\u0443\u0434\u0435."
    english: The guardians wake. Survive the judgement.
    portuguese: Os guardioes acordaram. Sobrevive ao julgamento.
  - key: boss.phase2
    russian: "\u0412\u0440\u0430\u0442\u0430 \u043E\u0442\u0432\u0435\u0447\u0430\u044E\u0442
      \u0441\u0438\u043B\u043E\u0439."
    english: The gate answers with force.
    portuguese: Os portoes respondem com forca.
  - key: speaker.gate
    russian: "\u0412\u0420\u0410\u0422\u0410"
    english: GATE
    portuguese: PORTOES
  - key: speaker.system
    russian: SYSTEM
    english: SYSTEM
    portuguese: SYSTEM
  - key: save.saved_at
    russian: '{0}  {1}'
    english: '{0}  {1}'
    portuguese: '{0}  {1}'
  - key: save.scene.exterior
    russian: "\u041A\u0432\u0430\u0434\u0440\u0430\u0442: \u0434\u0435\u043D\u044C"
    english: 'Square: day'
    portuguese: 'Quadrado: dia'
  - key: save.scene.night
    russian: "\u0417\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u044B\u0435 \u0430\u043B\u043B\u0435\u0438:
      \u043D\u043E\u0447\u044C"
    english: 'Protected alleys: night'
    portuguese: 'Becos protegidos: noite'
  - key: save.scene.final
    russian: "\u0424\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u0432\u0440\u0430\u0442\u0430"
    english: Final gate
    portuguese: Portoes finais
  - key: ending.restart
    russian: "\u041D\u0430\u0447\u0430\u0442\u044C \u0437\u0430\u043D\u043E\u0432\u043E"
    english: Start again
    portuguese: Recomecar
  - key: dialogue.continue
    russian: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
    english: Continue
    portuguese: Continuar
  - key: dialogue.next
    russian: "\u0414\u0430\u043B\u0435\u0435 ({0}/{1})"
    english: Next ({0}/{1})
    portuguese: Seguinte ({0}/{1})
  - key: raw.hunt.restart
    russian: "\u0422\u0435\u0431\u044F \u0432\u0435\u0440\u043D\u0443\u043B\u0438
      \u0432 \u043D\u0430\u0447\u0430\u043B\u043E. \u0421\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
      \u043F\u043E\u0431\u0435\u0433 \u0431\u0443\u0434\u0435\u0442 \u0442\u044F\u0436\u0435\u043B\u0435\u0435."
    english: You were returned to the beginning. The next escape will be harder.
    portuguese: Foste devolvido ao inicio. A proxima fuga sera mais dificil.
  - key: raw.hunt.purgatory
    russian: "\u0422\u0435\u043D\u0438 \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C
      \u0434\u043E \u0442\u0435\u0431\u044F. \u0422\u0435\u043F\u0435\u0440\u044C
      \u0442\u0435\u0431\u044F \u0436\u0434\u0435\u0442 \u0447\u0438\u0441\u0442\u0438\u043B\u0438\u0449\u0435.\n\n\u0422\u0435\u0431\u044F
      \u043D\u0435 \u0445\u043E\u0440\u043E\u043D\u044F\u0442. \u0422\u0435\u0431\u044F
      \u0444\u043E\u0440\u043C\u0430\u0442\u0438\u0440\u0443\u044E\u0442."
    english: 'The shadows reached you. Purgatory awaits.


      You are not buried.
      You are formatted.'
    portuguese: 'As sombras alcancaram-te. O purgatorio espera-te.


      Nao te
      enterram. Formatam-te.'
  - key: raw.fragment.day.prompt
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043B\u0435\u0436\u0438\u0442
      \u0442\u0430\u043C, \u0433\u0434\u0435 \u043D\u0430 \u0442\u0435\u0431\u044F
      \u0435\u0449\u0435 \u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0438 \u0431\u0435\u0437
      \u043F\u043E\u0433\u043E\u043D\u0438. \u041F\u043E\u0434\u043D\u044F\u0442\u044C
      \u0435\u0433\u043E?"
    english: The fragment lies where they still watched you without pursuit. Pick
      it up?
    portuguese: O fragmento esta onde ainda te observavam sem perseguir. Apanha-lo?
  - key: raw.fragment.night.prompt
    russian: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u043B\u0435\u0436\u0438\u0442 \u043F\u0435\u0440\u0435\u0434 \u0442\u043E\u0431\u043E\u0439.
      \u0412\u0437\u044F\u0442\u044C \u0435\u0433\u043E \u0441 \u0441\u043E\u0431\u043E\u0439?"
    english: The second fragment lies before you. Take it with you?
    portuguese: O segundo fragmento esta diante de ti. Leva-lo contigo?
  - key: raw.fragment.take
    russian: "\u041F\u043E\u0434\u043D\u044F\u0442\u044C"
    english: Pick up
    portuguese: Apanhar
  - key: raw.fragment.leave
    russian: "\u041E\u0441\u0442\u0430\u0432\u0438\u0442\u044C"
    english: Leave
    portuguese: Deixar
  - key: raw.fragment.day.collected
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u0440\u0438\u043D\u044F\u0442.
      \u041A\u0432\u0430\u0434\u0440\u0430\u0442 \u0443\u0437\u043D\u0430\u043B \u0442\u0435\u0431\u044F.
      \u0411\u0435\u0433\u0438 \u043A \u0437\u0434\u0430\u043D\u0438\u044E \u043D\u0430
      \u043E\u043A\u0440\u0430\u0438\u043D\u0435."
    english: Fragment accepted. The square recognized you. Run to the building at
      the edge.
    portuguese: Fragmento aceite. O quadrado reconheceu-te. Corre para o edificio
      na periferia.
  - key: raw.fragment.night.collected
    russian: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u043F\u0440\u0438\u043D\u044F\u0442. \u0422\u0435\u043F\u0435\u0440\u044C
      \u0412\u0440\u0430\u0442\u0430 \u0441\u043C\u043E\u0433\u0443\u0442 \u043D\u0430\u0437\u0432\u0430\u0442\u044C
      \u0446\u0435\u043D\u0443."
    english: Second fragment accepted. The Gate can now name its price.
    portuguese: Segundo fragmento aceite. Os Portoes podem agora indicar o preco.
  - key: raw.transition.locked.square
    russian: "\u0414\u0432\u0435\u0440\u044C \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430
      \u0437\u0430\u043A\u0440\u044B\u0442\u0430. \u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
      \u0435\u0449\u0435 \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u043E
      \u0442\u0432\u043E\u0439 \u043C\u0430\u0440\u0448\u0440\u0443\u0442."
    english: The square door is closed. The space has not recognized your route yet.
    portuguese: A porta do quadrado esta fechada. O espaco ainda nao reconheceu o
      teu percurso.
  - key: raw.transition.locked.first
    russian: "\u0412\u044B\u0445\u043E\u0434 \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0435\u0442
      \u0442\u0435\u0431\u044F \u0431\u0435\u0437 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430."
    english: The exit will not recognize you without the first fragment.
    portuguese: A saida nao te reconhecera sem o primeiro fragmento.
  - key: raw.transition.locked.second
    russian: "\u0414\u043E \u0412\u0440\u0430\u0442 \u043D\u0435\u043B\u044C\u0437\u044F
      \u0434\u043E\u0439\u0442\u0438 \u0431\u0435\u0437 \u0432\u0442\u043E\u0440\u043E\u0433\u043E
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430. \u0412\u0435\u0440\u043D\u0438\u0441\u044C
      \u0438 \u043F\u043E\u0434\u0431\u0435\u0440\u0438 \u0441\u043B\u0435\u0434
      \u043D\u043E\u0447\u0438."
    english: You cannot reach the Gate without the second fragment. Go back and pick
      up the night trace.
    portuguese: Nao podes chegar aos Portoes sem o segundo fragmento. Volta e apanha
      o rasto da noite.
  - key: raw.transition.prompt
    russian: "\u041F\u043E\u0440\u043E\u0433 \u043D\u0430\u0439\u0434\u0435\u043D.
      \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u043F\u0443\u0442\u044C?"
    english: Threshold found. Continue?
    portuguese: Limiar encontrado. Continuar?
  - key: raw.transition.enter
    russian: "\u0412\u043E\u0439\u0442\u0438"
    english: Enter
    portuguese: Entrar
  - key: raw.transition.leave
    russian: "\u041E\u0442\u043E\u0439\u0442\u0438"
    english: Step away
    portuguese: Recuar
  - key: raw.night.drop
    russian: "\u041F\u043B\u043E\u0449\u0430\u0434\u044C \u043E\u043F\u0443\u0441\u0442\u0435\u043B\u0430.
      \u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
      \u043D\u0430 \u0434\u043E\u0440\u043E\u0433\u0435. \u041F\u043E\u0434\u0431\u0435\u0440\u0438
      \u0435\u0433\u043E \u0438 \u0438\u0434\u0438 \u043A \u0412\u0440\u0430\u0442\u0430\u043C."
    english: The square is empty. The fragment appeared on the road. Pick it up and
      go to the Gate.
    portuguese: O quadrado ficou vazio. O fragmento apareceu na estrada. Apanha-o
      e vai aos Portoes.
  - key: raw.night.observe
    russian: "\u041D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438. \u041F\u0440\u043E\u0441\u0442\u043E
      \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438, \u0447\u0442\u043E \u043E\u043D\u0438
      \u0434\u0435\u043B\u0430\u044E\u0442 \u0434\u0440\u0443\u0433 \u0441 \u0434\u0440\u0443\u0433\u043E\u043C."
    english: Do not come closer. Watch what they do to each other.
    portuguese: Nao te aproximes. Observa o que fazem umas as outras.
  - key: raw.night.mercy
    russian: "\u041E\u043D\u0430 \u0432\u0441\u0442\u0430\u043B\u0430. \u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043D\u0430 \u0434\u043E\u0440\u043E\u0433\u0435.
      \u041F\u043E\u0434\u0431\u0435\u0440\u0438 \u0435\u0433\u043E \u0438 \u0438\u0434\u0438
      \u043A \u0412\u0440\u0430\u0442\u0430\u043C."
    english: She stood up. The fragment appeared on the road. Pick it up and go to
      the Gate.
    portuguese: Ela levantou-se. O fragmento apareceu na estrada. Apanha-o e vai
      aos Portoes.
  - key: raw.shadow.hit.first
    russian: "\u041D\u043E\u0447\u044C \u0437\u0430\u043F\u0438\u0441\u0430\u043B\u0430
      \u044D\u0442\u043E \u043A\u0430\u043A \u043F\u0440\u0430\u0432\u043E. \u0423\u0442\u0440\u043E
      \u043D\u0430\u0437\u043E\u0432\u0435\u0442 \u044D\u0442\u043E \u0434\u043E\u043B\u0433\u043E\u043C."
    english: The night recorded this as a right. Morning will call it a debt.
    portuguese: A noite registou isto como um direito. A manha chamar-lhe-a uma divida.
  - key: raw.shadow.hit
    russian: "\u041C\u044B \u0437\u043D\u0430\u043B\u0438, \u0447\u0442\u043E \u043D\u043E\u0447\u044C
      \u0432\u044B\u0431\u0435\u0440\u0435\u0442 \u0442\u0435\u0431\u044F."
    english: We knew the night would choose you.
    portuguese: Sabiamos que a noite te escolheria.
  - key: raw.npc.unknown
    russian: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, \u0437\u0430\u0447\u0435\u043C
      \u0442\u044B \u0437\u0434\u0435\u0441\u044C."
    english: I do not know why you are here.
    portuguese: Nao sei porque estas aqui.
  - key: raw.npc.help.prompt
    russian: "\u0415\u0441\u043B\u0438 \u0442\u044B \u043F\u043E\u043C\u043E\u0436\u0435\u0448\u044C
      \u043C\u043D\u0435, \u043E\u043D\u0438 \u0443\u0432\u0438\u0434\u044F\u0442
      \u0442\u0435\u0431\u044F."
    english: If you help me, they will see you.
    portuguese: Se me ajudares, eles vao ver-te.
  - key: raw.npc.help
    russian: "\u041F\u043E\u043C\u043E\u0447\u044C"
    english: Help
    portuguese: Ajudar
  - key: raw.npc.ignore
    russian: "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C"
    english: Ignore
    portuguese: Ignorar
  - key: raw.npc.push
    russian: "\u041E\u0442\u0442\u043E\u043B\u043A\u043D\u0443\u0442\u044C"
    english: Push away
    portuguese: Afastar
  - key: raw.npc.help.result
    russian: "\u0422\u044B \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E
      \u043D\u0435 \u0434\u043B\u044F \u043C\u0435\u043D\u044F. \u041D\u043E \u044F
      \u0437\u0430\u043F\u043E\u043C\u043D\u044E \u043E\u0434\u0438\u043D \u0446\u0438\u043A\u043B."
    english: You did not do it for me. But I will remember one cycle.
    portuguese: Nao fizeste isto por mim. Mas vou lembrar-me de um ciclo.
  - key: raw.npc.ignore.result
    russian: "\u0422\u0430\u043A \u043F\u0440\u043E\u0449\u0435. \u0422\u0430\u043A
      \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043B\u044E\u0431\u0438\u0442."
    english: It is easier this way. The system likes it this way.
    portuguese: Assim e mais simples. O sistema gosta assim.
  - key: raw.npc.push.result
    russian: "\u041D\u043E\u0447\u044C \u0431\u044B\u0441\u0442\u0440\u043E \u0443\u0447\u0438\u0442
      \u0442\u0435\u0431\u044F \u0431\u044B\u0442\u044C \u0441\u0438\u043B\u044C\u043D\u044B\u043C."
    english: The night quickly teaches you to be strong.
    portuguese: A noite ensina-te depressa a ser forte.
  - key: raw.gate.incomplete
    russian: "\u041C\u0430\u0440\u0448\u0440\u0443\u0442 \u043D\u0435\u043F\u043E\u043B\u043D\u044B\u0439.
      \u0412\u0435\u0440\u043D\u0438\u0441\u044C \u0438 \u0437\u0430\u0431\u0435\u0440\u0438
      \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u044E\u0449\u0438\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442."
    english: The route is incomplete. Go back and take the missing fragment.
    portuguese: A rota esta incompleta. Volta e apanha o fragmento em falta.
  - key: raw.gate.restart
    russian: "\u0421\u0442\u0440\u0430\u0436 \u043A\u043E\u0441\u043D\u0443\u043B\u0441\u044F
      \u0442\u0435\u0431\u044F. \u0421\u0443\u0434 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F
      \u0437\u0430\u043D\u043E\u0432\u043E."
    english: The guardian touched you. The trial starts again.
    portuguese: O guardiao tocou-te. O julgamento recomeca.
  - key: raw.gate.violent
    russian: "\u041D\u043E\u0447\u044C \u0437\u0430\u043F\u0438\u0441\u0430\u043B\u0430
      \u043F\u0443\u0442\u044C \u0441\u0438\u043B\u044B. \u0417\u0430\u0449\u0438\u0442\u043D\u0438\u043A\u0438
      \u043D\u0435 \u043F\u0440\u0438\u043C\u0443\u0442 \u0446\u0435\u043D\u0443
      \u0441\u043B\u043E\u0432\u0430\u043C\u0438. \u0412\u044B\u0436\u0438\u0432\u0438
      \u0438 \u043E\u0442\u043A\u0440\u043E\u0439 \u0412\u0440\u0430\u0442\u0430
      \u0441\u0438\u043B\u043E\u0439."
    english: The night recorded a path of force. The defenders will not accept words
      as a price. Survive and open the Gate by force.
    portuguese: A noite registou um caminho de forca. Os defensores nao aceitarao
      palavras como preco. Sobrevive e abre os Portoes pela forca.
  - key: raw.gate.peaceful.prompt
    russian: "\u0421\u0442\u0440\u0430\u0436\u0438 \u0437\u0430\u043A\u043E\u0432\u044B\u0432\u0430\u044E\u0442
      \u0442\u0435\u0431\u044F \u0432 \u0446\u0435\u043F\u0438 \u0438 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
      \u043D\u0430 \u0412\u0440\u0430\u0442\u0430. \u0412\u0441\u0435, \u0447\u0442\u043E
      \u0442\u044B \u0441\u043E\u0437\u0434\u0430\u0448\u044C, \u0431\u0443\u0434\u0435\u0442
      \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u043E; \u0432\u0441\u0435,
      \u043A\u0442\u043E \u0434\u043E\u0440\u043E\u0433, \u0443\u043C\u0440\u0443\u0442;
      \u0442\u044B \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0448\u044C \u043F\u0443\u0442\u044C.
      \u041D\u043E \u0435\u0441\u043B\u0438 \u0432\u0435\u0440\u043D\u0435\u0448\u044C\u0441\u044F,
      \u043D\u0435\u0441\u044F \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u0432\u043D\u0443\u0442\u0440\u0438,
      \u043E\u043D\u0438 \u043E\u0431\u0435\u0449\u0430\u044E\u0442 \u043B\u0443\u0447\u0448\u0443\u044E
      \u0436\u0438\u0437\u043D\u044C. \u0427\u0442\u043E \u0442\u044B \u0432\u044B\u0431\u0435\u0440\u0435\u0448\u044C?"
    english: The guardians chain you and point to the Gate. Everything you create
      will be destroyed; everyone dear to you will die; you will continue. But if
      you return carrying the second one within, they promise a better life. What
      do you choose?
    portuguese: Os guardioes acorrentam-te e apontam para os Portoes. Tudo o que
      criares sera destruido; todos os que amares morrerao; tu continuas. Mas se
      voltares trazendo o segundo dentro de ti, prometem uma vida melhor. O que escolhes?
  - key: raw.gate.pay
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u0432\u0441\u0435 \u0438 \u0432\u043E\u0439\u0442\u0438"
    english: Give everything and enter
    portuguese: Dar tudo e entrar
  - key: raw.gate.restart.choice
    russian: "\u041D\u0430\u0447\u0430\u0442\u044C \u0437\u0430\u043D\u043E\u0432\u043E"
    english: Start again
    portuguese: Recomecar
  - key: raw.guardian.hit
    russian: "\u0423\u0434\u0430\u0440 \u043F\u0440\u0438\u043D\u044F\u0442. \u0412\u0440\u0430\u0442\u0430
      \u0432\u0441\u0435 \u0435\u0449\u0435 \u0437\u0430\u043A\u0440\u044B\u0442\u044B."
    english: Hit accepted. The gate remains closed.
    portuguese: Golpe aceite. Os portoes continuam fechados.
  - key: raw.guardian.missing
    russian: "\u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043D\u0435
      \u043D\u0430\u0439\u0434\u0435\u043D\u043E. \u041F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
      \u043E\u0442\u043B\u043E\u0436\u0435\u043D\u0430."
    english: State not found. Evaluation postponed.
    portuguese: Estado nao encontrado. Avaliacao adiada.
  - key: raw.guardian.violent
    russian: "\u041D\u043E\u0447\u044C \u0437\u0430\u043F\u0438\u0441\u0430\u043B\u0430
      \u0441\u0438\u043B\u0443. \u0422\u0435\u043F\u0435\u0440\u044C \u043F\u0440\u043E\u0445\u043E\u0434
      \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F \u043E\u0442\u0441\u0442\u043E\u044F\u0442\u044C."
    english: The night recorded force. Now passage must be claimed by force.
    portuguese: A noite registou forca. Agora a passagem tera de ser reclamada pela
      forca.
  - key: raw.guardian.mercy
    russian: "\u0422\u044B \u0443\u0434\u0435\u0440\u0436\u0430\u043B \u0440\u0443\u043A\u0443.
      \u0421\u0438\u043B\u0430 \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u0442,
      \u0435\u0441\u043B\u0438 \u0442\u044B \u043E\u0442\u0434\u0430\u0448\u044C
      \u0432\u0441\u0435 \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E."
    english: You held your hand. Force will recede if you give everything willingly.
    portuguese: Contiveste a tua mao. A forca recuara se entregares tudo voluntariamente.
  - key: raw.guardian.price
    russian: "\u0414\u0432\u0430 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430,
      \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \u0436\u0438\u0437\u043D\u044C.
      \u0418\u043D\u0430\u0447\u0435 \u0432\u0440\u0430\u0442\u0430 \u043D\u0435
      \u043E\u0442\u043A\u0440\u043E\u044E\u0442\u0441\u044F."
    english: Two fragments, memory, and life. Otherwise the gate will not open.
    portuguese: Dois fragmentos, memoria e vida. Caso contrario, os portoes nao se
      abrem.
  - key: raw.final.gate
    russian: "\u041F\u0435\u0440\u0435\u0434 \u0442\u043E\u0431\u043E\u0439 \u0432\u043E\u0440\u043E\u0442\u0430.
      \u0418\u043B\u0438 \u0441\u0443\u0434. \u0418\u043B\u0438 \u043B\u043E\u0432\u0443\u0448\u043A\u0430."
    english: The gate is before you. Or a trial. Or a trap.
    portuguese: Os portoes estao diante de ti. Ou um julgamento. Ou uma armadilha.
  - key: raw.final.night
    russian: "\u041D\u043E\u0447\u043D\u0430\u044F \u0441\u0438\u043B\u0430 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0430.
      \u041C\u0438\u043B\u043E\u0441\u0435\u0440\u0434\u0438\u0435 \u043D\u0435 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u043E."
    english: Night strength confirmed. Mercy not confirmed.
    portuguese: Forca noturna confirmada. Misericordia nao confirmada.
  - key: raw.final.error
    russian: "\u041E\u0448\u0438\u0431\u043A\u0430 9. \u041E\u0431\u044A\u0435\u043A\u0442
      \u043D\u0435 \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C
      \u0437\u0434\u0435\u0441\u044C. \u041E\u0431\u044A\u0435\u043A\u0442 \u0432\u0441\u0451
      \u0435\u0449\u0451 \u0437\u0434\u0435\u0441\u044C."
    english: Error 9. The object should not be here. The object is still here.
    portuguese: Erro 9. O objeto nao devia estar aqui. O objeto ainda esta aqui.
  - key: raw.nonstep
    russian: "\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043E.
      \u0412\u0432\u043E\u0434 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0435\u043D.
      \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D.
      \u0422\u044B \u0441\u0434\u0435\u043B\u0430\u043B \u0432\u0441\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E,
      \u043D\u043E \u043F\u0440\u043E\u0445\u043E\u0434 \u0432\u0441\u0435 \u0440\u0430\u0432\u043D\u043E
      \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u043B\u0441\u044F."
    english: Action registered. Input correct. Result denied. You did everything
      right, but the passage still did not open.
    portuguese: Acao registada. Entrada correta. Resultado recusado. Fizeste tudo
      certo, mas a passagem nao abriu.
  - key: raw.altar.prompt
    russian: "\u041F\u0440\u043E\u0445\u043E\u0434 \u0442\u0440\u0435\u0431\u0443\u0435\u0442
      \u043F\u043E\u0442\u0435\u0440\u0438. \u0412\u044B\u0431\u0435\u0440\u0438,
      \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0442
      \u0431\u044B\u0442\u044C \u0442\u0432\u043E\u0438\u043C."
    english: Passage requires loss. Choose what will stop being yours.
    portuguese: A passagem exige perda. Escolhe o que deixara de ser teu.
  - key: raw.altar.memory
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u043F\u0430\u043C\u044F\u0442\u044C"
    english: Give memory
    portuguese: Dar memoria
  - key: raw.altar.name
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u0438\u043C\u044F"
    english: Give name
    portuguese: Dar nome
  - key: raw.altar.joy
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u0440\u0430\u0434\u043E\u0441\u0442\u044C"
    english: Give joy
    portuguese: Dar alegria
  - key: raw.altar.refuse
    russian: "\u041E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F"
    english: Refuse
    portuguese: Recusar
  - key: raw.altar.memory.result
    russian: "\u041F\u0430\u043C\u044F\u0442\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u0430.
      \u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435 \u043E
      \u0446\u0435\u043D\u0435 \u0443\u0434\u0430\u043B\u0435\u043D\u043E \u043D\u0435
      \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E."
    english: Memory accepted. The memory of the price was not fully deleted.
    portuguese: Memoria aceite. A memoria do preco nao foi totalmente eliminada.
  - key: raw.altar.name.result
    russian: "\u0418\u043C\u044F \u043F\u0440\u0438\u043D\u044F\u0442\u043E. \u041E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435
      \u043A \u0442\u0435\u0431\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435
      \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u0435\u0442 \u043E\u0442\u0432\u0435\u0442."
    english: Name accepted. Calling you no longer guarantees an answer.
    portuguese: Nome aceite. Chamar-te ja nao garante uma resposta.
  - key: raw.altar.joy.result
    russian: "\u0420\u0430\u0434\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u0430.
      \u0423\u043B\u044B\u0431\u043A\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0430
      \u043A\u0430\u043A \u0432\u043D\u0435\u0448\u043D\u0438\u0439 \u0436\u0435\u0441\u0442."
    english: Joy accepted. The smile was preserved as an external gesture.
    portuguese: Alegria aceite. O sorriso foi preservado como gesto exterior.
  - key: raw.altar.refuse.result
    russian: "\u041E\u0442\u043A\u0430\u0437 \u0437\u0430\u043F\u0438\u0441\u0430\u043D
      \u043A\u0430\u043A \u043B\u0438\u0448\u043D\u0435\u0435 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435."
    english: Refusal recorded as unnecessary movement.
    portuguese: Recusa registada como movimento desnecessario.
  - key: raw.ending.force.title
    russian: "\u0424\u0418\u041D\u0410\u041B: \u041F\u0423\u0422\u042C \u042F\u0420\u041E\u0421\u0422\u0418"
    english: 'ENDING: PATH OF RAGE'
    portuguese: 'FINAL: CAMINHO DA RAIVA'
  - key: raw.ending.force.text
    russian: "\u0422\u044B \u0440\u043E\u0434\u0438\u043B\u0441\u044F.\n\n\u0422\u044B
      \u043D\u0435 \u043F\u043E\u043C\u043D\u0438\u0448\u044C \u0432\u0441\u0435\u0433\u043E,
      \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0434\u043E
      \u0412\u0440\u0430\u0442. \u041D\u043E \u0432\u043D\u0443\u0442\u0440\u0438
      \u0442\u0435\u0431\u044F \u0432\u0441\u0435 \u0435\u0449\u0435 \u043A\u0438\u043F\u0438\u0442
      \u0442\u043E, \u0447\u0442\u043E \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u043E
      \u0443\u043C\u0435\u0440\u0435\u0442\u044C.\n\n\u0422\u0432\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0441 \u0442\u043E\u0431\u043E\u0439
      - \u043D\u0435 \u043A\u0430\u043A \u0441\u0432\u0435\u0442, \u0430 \u043A\u0430\u043A
      \u044F\u0440\u043E\u0441\u0442\u044C.\n\n\u0422\u0435\u043F\u0435\u0440\u044C
      \u0442\u044B \u0437\u0430\u043F\u0435\u0440\u0442 \u0432 \u043D\u043E\u0432\u043E\u043C
      \u0442\u0435\u043B\u0435 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
      \u0431\u0435\u0441\u0441\u0438\u043B\u0438\u0435\u043C. \u041A\u0430\u043A\u0438\u043C
      \u0431\u044B \u0437\u043B\u044B\u043C \u0442\u044B \u043D\u0438 \u0441\u0442\u0430\u043B,
      \u0442\u044B \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0435\u0448\u044C
      \u044F\u0440\u043E\u0441\u0442\u044C \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
      \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u0432\u043D\u0443\u0442\u0440\u0438.\n\n\u0418\u043D\u043E\u0433\u0434\u0430
      \u0442\u0435\u0431\u0435 \u0431\u0443\u0434\u0443\u0442 \u0441\u043D\u0438\u0442\u044C\u0441\u044F
      \u0442\u0435\u043D\u0438. \u041D\u043E \u043E\u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0435
      \u043D\u0435 \u0431\u0443\u0434\u0443\u0442 \u043F\u0440\u043E\u0441\u0438\u0442\u044C
      \u043E \u043F\u043E\u043C\u043E\u0449\u0438.\n\n\u041E\u043D\u0438 \u0431\u0443\u0434\u0443\u0442
      \u043F\u043E\u043C\u043D\u0438\u0442\u044C."
    english: 'You are born.


      You do not remember everything that happened
      before the Gate. But inside you, something that could not die is still boiling.


      Your
      fragment stayed with you, not as light, but as rage.


      Now you are locked
      inside a new body with your own helplessness. No matter how angry you become,
      you will never surpass the rage of what remains inside.


      Sometimes you
      will dream of shadows. But they will no longer ask for help.


      They will
      remember.'
    portuguese: 'Nasceste.


      Nao te lembras de tudo o que aconteceu antes dos
      Portoes. Mas dentro de ti ainda ferve algo que nao conseguiu morrer.


      O
      teu fragmento ficou contigo, nao como luz, mas como raiva.


      Agora estas
      preso num novo corpo com a tua propria impotencia. Por mais raiva que sintas,
      nunca vais ultrapassar a raiva daquilo que ficou dentro de ti.


      As vezes
      vais sonhar com sombras. Mas elas ja nao vao pedir ajuda.


      Elas vao
      lembrar-se.'
  - key: raw.ending.paid.title
    russian: "\u0424\u0418\u041D\u0410\u041B: \u041F\u0423\u0422\u042C \u0425\u0420\u0410\u041D\u0418\u0422\u0415\u041B\u042F"
    english: 'ENDING: PATH OF THE KEEPER'
    portuguese: 'FINAL: CAMINHO DO GUARDIAO'
  - key: raw.ending.paid.text
    russian: "\u0422\u044B \u0440\u043E\u0434\u0438\u043B\u0441\u044F.\n\n\u0422\u044B
      \u043D\u0435 \u043F\u043E\u043C\u043D\u0438\u0448\u044C \u0432\u0441\u0435\u0433\u043E,
      \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0434\u043E
      \u0412\u0440\u0430\u0442. \u041D\u043E \u0438\u043D\u043E\u0433\u0434\u0430
      \u0432\u043E \u0441\u043D\u0435 \u0442\u044B \u0432\u0438\u0434\u0438\u0448\u044C
      \u043E\u0434\u0438\u043D\u043E\u043A\u0443\u044E \u0442\u0435\u043D\u044C.\n\n\u041E\u043D\u0430
      \u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u043D\u0430 \u0442\u0435\u0431\u044F
      \u0438\u0437 \u0442\u0435\u043C\u043D\u043E\u0442\u044B - \u043D\u0435 \u0441
      \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C\u044E, \u0430 \u0441
      \u0442\u0438\u0445\u0438\u043C \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435\u043C.
      \u0411\u0443\u0434\u0442\u043E \u0432\u0441\u0435 \u0435\u0449\u0435 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
      \u0442\u0435\u0431\u0435 \u043D\u0430\u0439\u0442\u0438 \u043F\u0443\u0442\u044C.\n\n\u0422\u0432\u043E\u0439
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043E\u0441\u0442\u0430\u043B\u0441\u044F
      \u0432\u043D\u0443\u0442\u0440\u0438. \u0412 \u043D\u0435\u043C \u0432\u0441\u0435
      \u0435\u0449\u0435 \u0436\u0438\u0432\u0435\u0442 \u044F\u0440\u043E\u0441\u0442\u044C,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0442\u044B \u043C\u043E\u0433
      \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043D\u0430 \u043C\u0438\u0440.\n\n\u041D\u043E
      \u0442\u0435\u043F\u0435\u0440\u044C \u0442\u044B \u043D\u0435 \u0435\u0435
      \u043F\u043B\u0435\u043D\u043D\u0438\u043A.\n\n\u0422\u044B \u0435\u0435 \u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C.\n\n\u0418
      \u043E\u0434\u043D\u0430\u0436\u0434\u044B, \u043A\u043E\u0433\u0434\u0430
      \u043F\u0440\u0438\u0434\u0435\u0442 \u0432\u0440\u0435\u043C\u044F, \u0442\u044B
      \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0448\u044C, \u0437\u0430\u0447\u0435\u043C
      \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
      \u0432 \u0442\u0435\u0431\u0435."
    english: 'You are born.


      You do not remember everything that happened
      before the Gate. But sometimes, in sleep, you see a lone shadow.


      It
      watches you from the dark, not with hatred, but with quiet understanding. As
      if it is still helping you find the way.


      Your fragment stayed inside.
      In it, the rage you could have released into the world is still alive.


      But
      now you are not its prisoner.


      You are its keeper.


      And one day,
      when the time comes, you will remember why it was left inside you.'
    portuguese: 'Nasceste.


      Nao te lembras de tudo o que aconteceu antes dos
      Portoes. Mas as vezes, no sono, ves uma sombra solitaria.


      Ela olha
      para ti da escuridao, nao com odio, mas com uma compreensao silenciosa. Como
      se ainda te ajudasse a encontrar o caminho.


      O teu fragmento ficou dentro
      de ti. Nele ainda vive a raiva que poderias ter libertado sobre o mundo.


      Mas
      agora nao es prisioneiro dela.


      Es o seu guardiao.


      E um dia,
      quando chegar a hora, vais lembrar-te porque ela foi deixada dentro de ti.'
  - key: raw.ending.restart.prompt
    russian: "\u041A\u043E\u043D\u0435\u0446 \u0437\u0430\u043F\u0438\u0441\u0430\u043D.
      \u0426\u0438\u043A\u043B \u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0447\u0430\u0442\u044C\u0441\u044F
      \u0437\u0430\u043D\u043E\u0432\u043E."
    english: The ending is recorded. The cycle can begin again.
    portuguese: O final foi registado. O ciclo pode recomecar.
  - key: raw.npc.queue.1
    russian: "\u0422\u044B \u043D\u0435 \u0438\u0437 \u043E\u0447\u0435\u0440\u0435\u0434\u0438."
    english: You are not in the queue.
    portuguese: Tu nao estas na fila.
  - key: raw.npc.queue.2
    russian: "\u041D\u0435 \u0442\u043E\u043B\u043A\u0430\u0439\u0441\u044F. \u0417\u0434\u0435\u0441\u044C
      \u0436\u0434\u0443\u0442 \u0442\u0435, \u043A\u043E\u043C\u0443 \u0445\u043E\u0442\u044F
      \u0431\u044B \u043E\u0431\u0435\u0449\u0430\u043B\u0438 \u043C\u0435\u0441\u0442\u043E."
    english: Do not push. Those who were at least promised a place wait here.
    portuguese: Nao empurres. Aqui esperam aqueles a quem pelo menos prometeram um
      lugar.
  - key: raw.npc.queue.3
    russian: "\u0423 \u0442\u0435\u0431\u044F \u0434\u0430\u0436\u0435 \u0438\u043C\u0435\u043D\u0438
      \u043D\u0435\u0442."
    english: You do not even have a name.
    portuguese: Tu nem sequer tens nome.
  - key: raw.npc.witness.1
    russian: "\u0421\u043C\u043E\u0442\u0440\u0438."
    english: Watch.
    portuguese: Observa.
  - key: raw.npc.witness.2
    russian: "\u041E\u043D \u0434\u0443\u043C\u0430\u0435\u0442, \u0447\u0442\u043E
      \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442."
    english: He thinks he is choosing.
    portuguese: Ele pensa que esta a escolher.
  - key: raw.npc.witness.3
    russian: "\u041E\u043D \u0435\u0449\u0451 \u043D\u0435 \u043F\u043E\u043D\u044F\u043B,
      \u0447\u0442\u043E \u0432\u0445\u043E\u0434 \u0443\u0436\u0435 \u0437\u0430\u043F\u0438\u0441\u0430\u043D."
    english: He still has not realized that the entrance has already been recorded.
    portuguese: Ele ainda nao percebeu que a entrada ja foi registada.
  - key: raw.npc.pleading
    russian: "\u041D\u0435 \u0433\u043E\u043D\u0438\u0441\u044C \u0437\u0430 \u043C\u043D\u043E\u0439
      \u0440\u0430\u0434\u0438 \u0443\u0434\u0430\u0440\u0430. \u0421\u043C\u043E\u0442\u0440\u0438,
      \u0447\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u0442\u0441\u044F \u0434\u0430\u043B\u044C\u0448\u0435."
    english: Do not chase me just to strike. Watch what happens next.
    portuguese: Nao me persigas apenas para atacar. Observa o que acontece a seguir.
  - key: raw.npc.observer.1
    russian: "\u041A\u0432\u0430\u0434\u0440\u0430\u0442 \u043F\u043E\u043C\u043D\u0438\u0442
      \u0442\u0432\u043E\u0438 \u0448\u0430\u0433\u0438, \u0434\u0430\u0436\u0435
      \u0435\u0441\u043B\u0438 \u0442\u044B \u043D\u0435\u0442."
    english: The square remembers your steps, even if you do not.
    portuguese: O quadrado lembra-se dos teus passos, mesmo que tu nao.
  - key: raw.npc.observer.2
    russian: "\u0426\u0435\u043D\u0430 \u0432\u0441\u0435\u0433\u0434\u0430 \u0432\u044B\u0448\u0435
      \u043D\u043E\u0447\u044C\u044E. \u0422\u044B \u0433\u043E\u0442\u043E\u0432
      \u043F\u043B\u0430\u0442\u0438\u0442\u044C?"
    english: The price is always higher at night. Are you ready to pay?
    portuguese: O preco e sempre mais alto a noite. Estas pronto para pagar?
  - key: raw.npc.whisperer.1
    russian: "\u041D\u0435 \u0441\u043C\u043E\u0442\u0440\u0438 \u0432 \u043E\u043A\u043D\u0430.
      \u041E\u043D\u0438 \u043F\u0443\u0441\u0442\u044B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0442\u0430\u043A."
    english: Do not look into the windows. They are empty for a reason.
    portuguese: Nao olhes para as janelas. Elas estao vazias por uma razao.
  - key: raw.npc.whisperer.2
    russian: "\u0422\u044B \u043F\u0435\u0440\u0432\u044B\u0439 \u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442,
      \u0434\u043E\u0431\u0440\u0430\u0432\u0448\u0438\u0439\u0441\u044F \u0434\u043E
      \u044D\u0442\u043E\u0433\u043E \u0446\u0438\u043A\u043B\u0430."
    english: You are the first Fragment to reach this cycle.
    portuguese: Es o primeiro Fragmento a chegar a este ciclo.
  - key: raw.npc.afraid.neutral
    russian: "\u041D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438 \u0440\u0435\u0437\u043A\u043E.
      \u042F \u0432\u0441\u0435 \u0435\u0449\u0435 \u043F\u044B\u0442\u0430\u044E\u0441\u044C
      \u0432\u0441\u0442\u0430\u0442\u044C."
    english: Do not approach suddenly. I am still trying to stand up.
    portuguese: Nao te aproximes de repente. Ainda estou a tentar levantar-me.
  - key: raw.npc.afraid.mercy
    russian: "\u0422\u044B \u043D\u0435 \u0443\u0434\u0430\u0440\u0438\u043B. \u0417\u043D\u0430\u0447\u0438\u0442,
      \u0437\u0434\u0435\u0441\u044C \u0435\u0449\u0435 \u043C\u043E\u0436\u043D\u043E
      \u043F\u043E\u0434\u043D\u044F\u0442\u044C\u0441\u044F."
    english: You did not strike. Then it is still possible to stand up here.
    portuguese: Nao atacaste. Entao ainda e possivel levantar-se aqui.
  - key: raw.npc.afraid.violent
    russian: "\u042F \u0432\u0438\u0434\u0435\u043B, \u0447\u0442\u043E \u0442\u044B
      \u0441\u0434\u0435\u043B\u0430\u043B. \u041D\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u0439
      \u044D\u0442\u043E \u0432\u044B\u0445\u043E\u0434\u043E\u043C."
    english: I saw what you did. Do not call it an exit.
    portuguese: Eu vi o que fizeste. Nao lhe chames uma saida.
  - key: raw.npc.ally.neutral
    russian: "\u041A \u0432\u043E\u0440\u043E\u0442\u0430\u043C \u0432\u0435\u0434\u0435\u0442
      \u0443\u043B\u0438\u0446\u0430, \u043D\u043E \u0432\u044B\u0431\u043E\u0440
      \u0438\u0434\u0435\u0442 \u0440\u044F\u0434\u043E\u043C \u0441 \u0442\u043E\u0431\u043E\u0439."
    english: A street leads to the gate, but the choice walks beside you.
    portuguese: Uma rua leva aos portoes, mas a escolha caminha ao teu lado.
  - key: raw.npc.ally.mercy
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
      \u043D\u0435 \u0438\u0437 \u0441\u043C\u0435\u0440\u0442\u0438. \u0421\u043E\u0445\u0440\u0430\u043D\u0438
      \u044D\u0442\u043E \u0434\u043E \u0432\u043E\u0440\u043E\u0442."
    english: The fragment did not come from death. Keep that with you until the gate.
    portuguese: O fragmento nao surgiu da morte. Guarda isso contigo ate aos portoes.
  - key: raw.npc.ally.violent
    russian: "\u0412\u0440\u0430\u0442\u0430 \u0443\u0437\u043D\u0430\u044E\u0442,
      \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043D\u0435\u0439 \u0442\u044B
      \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043B\u0435\u0436\u0430\u0442\u044C."
    english: The gate will know how many shadows you left lying down.
    portuguese: Os portoes saberao quantas sombras deixaste caidas.
  - key: raw.exterior.fragment.awakening
    russian: "\u0424\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u043F\u0440\u0438\u043D\u044F\u0442.
      \u0421\u0432\u0435\u0442 \u043D\u0430 \u0442\u0435\u0431\u0435 \u0431\u0443\u0434\u0435\u0442
      \u0432\u0435\u0441\u0442\u0438 \u043A \u0412\u0440\u0430\u0442\u0430\u043C.
      \u0422\u0435\u043D\u0438 \u0442\u043E\u0436\u0435 \u0443\u0432\u0438\u0434\u0435\u043B\u0438
      \u0435\u0433\u043E."
    english: Fragment accepted. The light on you will lead to the Gate. The shadows
      saw it too.
    portuguese: Fragmento aceite. A luz em ti vai guiar-te aos Portoes. As sombras
      tambem a viram.
  - key: raw.exterior.gate.reveal
    russian: "\u0412\u0440\u0430\u0442\u0430 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
      \u043D\u0430 \u043A\u0440\u0430\u044E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430."
    english: The Gate appeared at the edge of the square.
    portuguese: Os Portoes apareceram na beira do quadrado.
  - key: raw.exterior.gate.claim
    russian: "\u0422\u044B \u0435\u0449\u0435 \u043D\u0435 \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D.
      \u0418\u0434\u0438 \u0436\u0435 \u0438 \u0432\u043E\u0437\u044C\u043C\u0438."
    english: You have not been chosen yet. Go, then, and take.
    portuguese: Ainda nao foste escolhido. Vai, entao, e toma.
  - key: raw.exterior.gate.collapse
    russian: "\u041E\u0433\u043E\u043D\u0435\u043A \u0432\u0441\u043F\u044B\u0445\u0438\u0432\u0430\u0435\u0442.
      \u0423\u0434\u0430\u0440 \u043B\u043E\u043C\u0430\u0435\u0442 \u043A\u043E\u043D\u0442\u0443\u0440
      \u0434\u0432\u0435\u0440\u0438, \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442
      \u043D\u0430 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435 \u0441\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0432\u043D\u0443\u0442\u0440\u044C \u0441\u0435\u0431\u044F."
    english: The light flares. The strike breaks the door's outline, and for a moment
      the square collapses into itself.
    portuguese: A luz irrompe. O golpe quebra o contorno da porta, e por um instante
      o quadrado colapsa para dentro de si.
  - key: raw.exterior.gate.cutscene.found
    russian: "\u0422\u044B \u0434\u043E\u0448\u0435\u043B \u0434\u043E \u0412\u0440\u0430\u0442.
      \u041E\u043D\u0438 \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F
      \u043E\u0442 \u043E\u0434\u043D\u043E\u0433\u043E \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430."
    english: You reached the Gate. One fragment is not enough to open it.
    portuguese: Chegaste aos Portoes. Um fragmento nao basta para os abrir.
  - key: raw.exterior.gate.cutscene.vision
    russian: "\u041F\u043E\u0437\u0430\u0434\u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u044E\u0442\u0441\u044F
      \u0442\u0435\u043D\u0438. \u041E\u043D\u0438 \u0432\u0438\u0434\u044F\u0442
      \u043F\u0443\u0442\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u044B
      \u0443\u043A\u0440\u0430\u043B \u0443 \u0441\u0438\u0441\u0442\u0435\u043C\u044B."
    english: Shadows gather behind you. They see the route you stole from the System.
    portuguese: As sombras juntam-se atras de ti. Veem a rota que roubaste ao Sistema.
  - key: raw.exterior.gate.cutscene.prompt
    russian: "\u0412\u044B\u0441\u0442\u0440\u0435\u043B\u0438 \u0432\u043E \u0412\u0440\u0430\u0442\u0430,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0439\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435."
    english: Shoot the Gate to move forward.
    portuguese: Dispara contra os Portoes para avancar.
  - key: raw.exterior.gate.cutscene.shadows
    russian: "\u0422\u044B \u043E\u0431\u0435\u0440\u043D\u0443\u043B\u0441\u044F.
      \u0422\u0435\u043D\u0438 \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435
      \u043D\u0430\u043F\u0430\u0434\u0430\u044E\u0442. \u041E\u043D\u0438 \u0441\u043C\u043E\u0442\u0440\u044F\u0442,
      \u043A\u0430\u043A \u043F\u0440\u043E\u0445\u043E\u0434 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F."
    english: You turned back. The shadows around you do not attack. They watch the
      passage open.
    portuguese: Olhaste para tras. As sombras a tua volta nao atacam. Observam a
      passagem abrir.
  - key: raw.exterior.gate.cutscene.impossible
    russian: "\u041F\u0440\u043E\u0445\u043E\u0434 \u043E\u0442\u043A\u0440\u044B\u0442.
      \u041F\u0435\u0440\u0432\u044B\u0439 \u043A\u0432\u0430\u0434\u0440\u0430\u0442
      \u043E\u0442\u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u0442\u0435\u0431\u044F."
    english: The passage is open. The first square lets you go.
    portuguese: A passagem esta aberta. O primeiro quadrado deixa-te partir.
  - key: raw.night.intro.square
    russian: "\u0422\u044B \u043F\u0440\u043E\u0448\u0435\u043B \u0447\u0435\u0440\u0435\u0437
      \u0412\u0440\u0430\u0442\u0430 \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
      \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u043C \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0435."
    english: You passed through the Gate and entered the second square.
    portuguese: Passaste pelos Portoes e entraste no segundo quadrado.
  - key: raw.night.intro.attack
    russian: "\u041D\u043E\u0447\u044C \u0434\u0430\u0435\u0442 \u0442\u0435\u0431\u0435
      \u0441\u0438\u043B\u0443 \u0443\u0434\u0430\u0440\u0430. \u0421\u043D\u0430\u0447\u0430\u043B\u0430
      \u043F\u0440\u043E\u0432\u0435\u0440\u044C \u0435\u0435 \u043D\u0430 \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439
      \u0442\u0435\u043D\u0438."
    english: The night gives you a strike. Test it on the still shadow first.
    portuguese: A noite da-te um golpe. Testa-o primeiro na sombra parada.
  - key: raw.night.intro.shadows
    russian: "\u0416\u0438\u0432\u044B\u0435 \u0442\u0435\u043D\u0438 \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E\u0442
      \u044D\u0442\u0443 \u0441\u0438\u043B\u0443. \u041E\u0434\u043D\u0438 \u0438\u0441\u043F\u0443\u0433\u0430\u044E\u0442\u0441\u044F.
      \u0414\u0440\u0443\u0433\u0438\u0435 \u043D\u0430\u0447\u043D\u0443\u0442 \u043E\u0445\u043E\u0442\u0443."
    english: Living shadows will feel that force. Some will fear it. Others will
      hunt.
    portuguese: As sombras vivas vao sentir essa forca. Algumas terao medo. Outras
      vao cacar.
  - key: raw.night.intro.hunted
    russian: "\u0412\u044B\u0431\u043E\u0440 \u043F\u0440\u043E\u0441\u0442\u043E\u0439:
      \u043F\u0440\u043E\u0439\u0442\u0438 \u043C\u0438\u043C\u043E \u0438\u043B\u0438
      \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044C \u043D\u043E\u0447\u044C
      \u0432 \u0431\u043E\u0439. \u0412\u0442\u043E\u0440\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
      \u0442\u0432\u043E\u0435\u0433\u043E \u0432\u044B\u0431\u043E\u0440\u0430."
    english: 'The choice is simple: pass through, or turn the night into a fight.
      The second fragment appears after your choice.'
    portuguese: 'A escolha e simples: passa adiante ou transforma a noite numa luta.
      O segundo fragmento aparece depois da tua escolha.'
  - key: raw.night.exit.cast
    russian: "\u0413\u0435\u0440\u043E\u0439 \u0431\u0440\u043E\u0441\u0430\u0435\u0442
      \u0441\u043D\u0430\u0440\u044F\u0434 \u0432 \u0434\u0432\u0435\u0440\u044C.
      \u041D\u043E\u0447\u044C \u043D\u0435 \u043E\u0442\u0441\u0442\u0443\u043F\u0430\u0435\u0442,
      \u043D\u043E \u0441\u0442\u0432\u043E\u0440\u043A\u0438 \u0441\u043D\u043E\u0432\u0430
      \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F."
    english: The hero throws a projectile into the door. The night does not retreat,
      but the doors open again.
    portuguese: O heroi lanca um projetil contra a porta. A noite nao recua, mas
      as portas abrem-se outra vez.
  - key: raw.night.exit.fragment
    russian: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442
      \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0432\u043D\u0443\u0442\u0440\u0438
      \u0442\u0435\u0431\u044F: \u043C\u044B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u043E\u0441\u043A\u043E\u043B\u043A\u0438. \u041C\u044B \u0447\u0430\u0441\u0442\u0438
      \u0432\u0435\u043B\u0438\u043A\u0438\u0445, \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043B\u0438
      \u044D\u0442\u043E\u0442 \u043C\u0438\u0440."
    english: 'The second fragment speaks inside you: we are not mere shards. We are
      parts of the great ones who created this world.'
    portuguese: 'O segundo fragmento fala dentro de ti: nao somos meros estilhacos.
      Somos partes dos grandes que criaram este mundo.'
  - key: raw.night.exit.mercy
    russian: "\u041E\u043D\u0438 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438
      \u0441\u043D\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043A
      \u043A\u0430\u0436\u0434\u043E\u043C\u0443, \u0438 \u043F\u043E\u0442\u043E\u043C\u0443
      \u044D\u0442\u0438 \u0442\u0435\u043D\u0438 \u0441\u043A\u0438\u0442\u0430\u044E\u0442\u0441\u044F
      \u0432 \u043C\u0438\u0440\u0430\u0445, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0445
      \u0434\u043B\u044F \u043D\u0438\u0445. \u0422\u0435\u043F\u0435\u0440\u044C
      \u0442\u044B \u043D\u0435\u0441\u0435\u0448\u044C \u044D\u0442\u043E \u0437\u043D\u0430\u043D\u0438\u0435
      \u043A \u0412\u0440\u0430\u0442\u0430\u043C."
    english: They showed mercy to each one, and so these shadows wander through worlds
      made for them. Now you carry that knowledge to the Gate.
    portuguese: Eles mostraram misericordia a cada um, e por isso estas sombras vagueiam
      por mundos feitos para elas. Agora levas esse conhecimento aos Portoes.
  - key: raw.final.intro.guardians
    russian: "\u041F\u0435\u0440\u0435\u0434 \u0412\u0440\u0430\u0442\u0430\u043C\u0438
      \u0441\u0442\u043E\u044F\u0442 \u0441\u0442\u0440\u0430\u0436\u0438. \u041E\u043D\u0438
      \u0437\u0430\u0449\u0438\u0449\u0430\u044E\u0442 \u043F\u043E\u0440\u044F\u0434\u043E\u043A
      \u043E\u0442 \u043E\u0448\u0438\u0431\u043E\u043A \u0432\u0440\u043E\u0434\u0435
      \u0442\u0435\u0431\u044F."
    english: Guardians stand before the Gate. They protect order from errors like
      you.
    portuguese: Guardioes estao diante dos Portoes. Protegem a ordem de erros como
      tu.
  - key: raw.final.intro.boundaries
    russian: "\u0417\u0434\u0435\u0441\u044C \u043A\u0430\u0436\u0434\u044B\u0439
      \u0448\u0430\u0433 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D.
      \u0421\u0442\u0440\u0430\u0436\u0438 \u0434\u0435\u0440\u0436\u0430\u0442 \u0433\u0440\u0430\u043D\u0438\u0446\u044B
      \u0441\u0432\u043E\u0435\u0439 \u0432\u043E\u043B\u0435\u0439."
    english: Every step is limited here. The guardians hold the boundaries by will.
    portuguese: Aqui cada passo e limitado. Os guardioes seguram as fronteiras pela
      vontade.
  - key: raw.final.intro.violent
    russian: "\u0422\u044B \u043F\u0440\u0438\u043D\u0435\u0441 \u0434\u043E\u043B\u0433
      \u043D\u043E\u0447\u0438. \u0414\u043B\u044F \u0412\u0440\u0430\u0442 \u044D\u0442\u043E
      \u043F\u0443\u0442\u044C \u0441\u0438\u043B\u044B."
    english: You brought the debt of the night. To the Gate, this is the path of
      force.
    portuguese: Trouxeste a divida da noite. Para os Portoes, este e o caminho da
      forca.
  - key: raw.final.intro.attack
    russian: "\u0421\u0442\u0440\u0430\u0436\u0438 \u043D\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0430\u0442
      \u0446\u0435\u043D\u0443. \u041E\u043D\u0438 \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u044E\u0442
      \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u0442\u0435\u0431\u044F."
    english: The guardians will not offer a price. They will try to stop you.
    portuguese: Os guardioes nao vao oferecer um preco. Vao tentar travar-te.
  - key: raw.final.intro.peaceful
    russian: "\u0422\u044B \u043F\u0440\u0438\u043D\u0435\u0441 \u0432\u0442\u043E\u0440\u043E\u0439
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442, \u043D\u043E \u043D\u0435
      \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u043D\u043E\u0447\u044C
      \u0432 \u0431\u043E\u0439."
    english: You brought the second fragment without turning the night into a fight.
    portuguese: Trouxeste o segundo fragmento sem transformar a noite numa luta.
  - key: raw.final.intro.queue
    russian: "\u0412\u0440\u0430\u0442\u0430 \u0432\u0438\u0434\u044F\u0442 \u043E\u0448\u0438\u0431\u043A\u0443,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u043E\u0448\u043B\u0430 \u0434\u043E
      \u043A\u043E\u043D\u0446\u0430 \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u0430."
    english: The Gate sees an error that reached the end of the route.
    portuguese: Os Portoes veem um erro que chegou ao fim da rota.
  - key: raw.final.intro.offer
    russian: "\u0422\u0435\u043F\u0435\u0440\u044C \u043E\u043D\u0438 \u043D\u0430\u0437\u043E\u0432\u0443\u0442
      \u0446\u0435\u043D\u0443. \u0422\u044B \u0432\u044B\u0431\u0435\u0440\u0435\u0448\u044C,
      \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0441 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430\u043C\u0438."
    english: Now they will name the price. You choose what to do with the fragments.
    portuguese: Agora vao indicar o preco. Tu escolhes o que fazer com os fragmentos.
  - key: raw.final.bound.1
    russian: "\u041E\u0441\u0442\u0430\u0442\u043A\u0438 \u0434\u0443\u0448 \u0441\u043A\u043E\u0432\u044B\u0432\u0430\u044E\u0442
      \u0442\u0435\u0431\u044F. \u0422\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0448\u044C
      \u0448\u0435\u043B\u043E\u0445\u043D\u0443\u0442\u044C\u0441\u044F, \u0445\u043E\u0442\u044F
      \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0448\u044C, \u043A\u0430\u043A
      \u0446\u0435\u043F\u0438 \u0443\u0436\u0435 \u0442\u0440\u0435\u0449\u0430\u0442."
    english: The remnants of souls bind you. You cannot move, though you feel the
      chains already cracking.
    portuguese: Os restos das almas prendem-te. Nao consegues mover-te, embora sintas
      as correntes ja a rachar.
  - key: raw.final.bound.2
    russian: "\u041C\u044B \u043D\u0435 \u0443\u0434\u0435\u0440\u0436\u0438\u043C
      \u0442\u0435\u0431\u044F \u0434\u043E\u043B\u0433\u043E. \u041D\u043E \u044D\u0442\u043E\u0433\u043E
      \u0445\u0432\u0430\u0442\u0438\u0442, \u0447\u0442\u043E\u0431\u044B \u0412\u0440\u0430\u0442\u0430
      \u0437\u0430\u043F\u0438\u0441\u0430\u043B\u0438 \u0442\u0432\u043E\u0439 \u043F\u0443\u0442\u044C
      \u043A\u0430\u043A \u044F\u0440\u043E\u0441\u0442\u044C."
    english: We will not hold you for long. But it will be enough for the Gate to
      record your path as rage.
    portuguese: Nao te vamos segurar por muito tempo. Mas bastara para os Portoes
      registarem o teu caminho como raiva.
  - key: raw.gate.accept.chains
    russian: "\u041F\u0440\u0438\u043D\u044F\u0442\u044C \u0446\u0435\u043F\u0438"
    english: Accept the chains
    portuguese: Aceitar as correntes
  - key: raw.gate.fight
    russian: "\u0414\u0440\u0430\u0442\u044C\u0441\u044F"
    english: Fight
    portuguese: Lutar
  - key: raw.gate.destroy
    russian: "\u0423\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u044B"
    english: Destroy the fragments
    portuguese: Destruir os fragmentos
  - key: raw.gate.accept.1
    russian: "\u0422\u044B \u0438\u0434\u0435\u0448\u044C \u043A \u0412\u0440\u0430\u0442\u0430\u043C
      \u0432 \u0446\u0435\u043F\u044F\u0445. \u0412\u043D\u0443\u0442\u0440\u0438
      \u043A\u0438\u043F\u0438\u0442 \u0432\u0442\u043E\u0440\u043E\u0439, \u0442\u043E\u0442,
      \u043A\u043E\u0433\u043E \u0442\u044B \u043D\u0435 \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B
      \u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0440\u0443\u0447\u043D\u043E
      \u0437\u0430\u043A\u043E\u0432\u0430\u043B."
    english: You walk to the Gate in chains. Inside you boils the second one, the
      one you did not release and chained with your own hands.
    portuguese: Caminhas para os Portoes acorrentado. Dentro de ti ferve o segundo,
      aquele que nao libertaste e que prendeste com as tuas proprias maos.
  - key: raw.gate.accept.2
    russian: "\u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u043F\u0443\u0442\u044C \u043F\u0440\u043E\u0439\u0442\u0438 - \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0441\u0438\u043B\u0443 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430
      \u0432 \u043C\u043E\u043C\u0435\u043D\u0442 \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430:
      \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C \u0447\u0430\u0441\u0442\u044C
      \u043F\u0430\u043C\u044F\u0442\u0438 \u0438 \u0432\u043C\u0435\u0441\u0442\u0435
      \u0441\u043E \u0432\u0442\u043E\u0440\u044B\u043C \u043F\u0440\u043E\u0431\u0438\u0442\u044C\u0441\u044F
      \u0432\u043D\u0443\u0442\u0440\u044C, \u0447\u0442\u043E\u0431\u044B \u0440\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0447\u0435\u043C-\u0442\u043E \u043D\u043E\u0432\u044B\u043C."
    english: 'The only way through is to use the fragment''s power at the moment
      of crossing: keep part of memory and break through with the second one to be
      born as something new.'
    portuguese: 'A unica forma de passar e usar a forca do fragmento no momento da
      travessia: guardar parte da memoria e romper com o segundo para nascer como
      algo novo.'
  - key: raw.ending.destroy.title
    russian: "\u0424\u0418\u041D\u0410\u041B: \u0424\u0420\u0410\u0413\u041C\u0415\u041D\u0422
      \u041F\u041E\u0413\u0410\u0428\u0415\u041D"
    english: 'ENDING: FRAGMENT EXTINGUISHED'
    portuguese: 'FINAL: FRAGMENTO APAGADO'
  - key: raw.ending.destroy.text
    russian: "\u0423\u0441\u0438\u043B\u0438\u0435\u043C \u0432\u043E\u043B\u0438
      \u0442\u044B \u0433\u0430\u0441\u0438\u0448\u044C \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u044B.\n\n\u0412\u0441\u0435
      \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u0442\u0438\u0448\u0435. \u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
      \u043A\u0443\u0441\u043E\u0447\u0435\u043A \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u0435\u0442
      \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432
      \u044D\u0442\u043E\u043C \u043C\u0438\u0440\u0435.\n\n\u0418 \u0432\u043C\u0435\u0441\u0442\u0435
      \u0441 \u043D\u0438\u043C \u0433\u0430\u0441\u043D\u0435\u0442 \u0447\u0430\u0441\u0442\u044C
      \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0433\u043E \u0441\u0447\u0430\u0441\u0442\u044C\u044F.\n\n\u0421\u0438\u0441\u0442\u0435\u043C\u0430
      \u043D\u0435 \u043D\u0430\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0442\u0435\u0431\u044F.
      \u0415\u0439 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0447\u0435\u0433\u043E
      \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C."
    english: 'By force of will, you extinguish the fragments.


      Everything
      around you becomes quieter. A small piece stops existing in this world.


      With
      it, part of possible happiness also goes dark.


      The system does not
      punish you. It has nothing left to record.'
    portuguese: 'Por vontade propria, apagas os fragmentos.


      Tudo a tua volta
      fica mais silencioso. Um pequeno pedaco deixa de existir neste mundo.


      Com
      ele, uma parte da felicidade possivel tambem se apaga.


      O sistema nao
      te pune. Ja nao tem nada para registar.'
  - key: hud.boundary.exterior.blocked
    russian: "\u0414\u0430\u043B\u044C\u0448\u0435 \u0437\u043E\u043D\u0430 \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u0430
      \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F.
      \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E \u0442\u0435\u0431\u044F
      \u0432\u043D\u0443\u0442\u0440\u044C."
    english: The prototype area ends here. Moving you back inside.
    portuguese: "A \xE1rea do prot\xF3tipo acaba aqui. Vou p\xF4r-te de volta dentro."
  - key: hud.boundary.exterior.escape
    russian: "\u0422\u044B \u0432\u044B\u043F\u0430\u043B \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u044B
      \u0441\u0446\u0435\u043D\u044B. \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E
      \u043A \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435."
    english: You left the scene bounds. Returning you to a safe point.
    portuguese: "Sa\xEDste dos limites da cena. A voltar para um ponto seguro."
  - key: raw.return_gate.prompt
    russian: "\u041E\u0431\u0440\u0430\u0442\u043D\u044B\u0435 \u0432\u0440\u0430\u0442\u0430
      \u043E\u0442\u043A\u0440\u044B\u0442\u044B. \u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
      \u043A \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0435\u043C\u0443 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443?"
    english: The return gate is open. Go back to the previous square?
    portuguese: Os portoes de regresso estao abertos. Voltar ao quadrado anterior?
  - key: raw.return_gate.locked
    russian: "\u041E\u0431\u0440\u0430\u0442\u043D\u044B\u0439 \u043C\u0430\u0440\u0448\u0440\u0443\u0442
      \u0435\u0449\u0435 \u043D\u0435 \u0437\u0430\u043F\u0438\u0441\u0430\u043D.
      \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0443\u0436\u0435\u043D \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442."
    english: The return route is not recorded yet. A fragment must anchor it first.
    portuguese: A rota de regresso ainda nao foi registada. Primeiro precisas de
      um fragmento.
  - key: raw.return_gate.enter
    russian: "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F"
    english: Return
    portuguese: Voltar
  - key: raw.return_gate.leave
    russian: "\u041E\u0441\u0442\u0430\u0442\u044C\u0441\u044F"
    english: Stay
    portuguese: Ficar
  - key: raw.night.training.prompt
    russian: "\u0421\u0438\u043B\u0430 \u0443\u0436\u0435 \u0432 \u0440\u0443\u043A\u0435.
      \u0423\u0434\u0430\u0440\u044C \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0443\u044E
      \u0442\u0435\u043D\u044C, \u0437\u0430\u0442\u0435\u043C \u043D\u0430\u0436\u043C\u0438
      \xAB\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C\xBB."
    english: The force is already in your hand. Strike the still shadow, then press
      Continue.
    portuguese: A forca ja esta na tua mao. Atinge a sombra parada e depois prime
      Continuar.
  - key: raw.night.training.hit
    russian: "\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
      \u0442\u0440\u0435\u0441\u043D\u0443\u043B\u043E. \u0416\u0438\u0432\u044B\u0435
      \u0442\u0435\u043D\u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u0442\u043E\u0436\u0435
      \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E\u0442 \u0443\u0434\u0430\u0440."
    english: The space cracked. The living shadows will feel the strike now.
    portuguese: O espaco rachou. As sombras vivas vao sentir o golpe agora.
  - key: raw.night.training.release
    russian: "\u041D\u043E\u0447\u044C \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0430
      \u0442\u0432\u043E\u044E \u0441\u0438\u043B\u0443. \u0422\u0435\u043F\u0435\u0440\u044C
      \u0434\u0432\u0438\u0433\u0430\u0439\u0441\u044F: \u0436\u0438\u0432\u044B\u0435
      \u0442\u0435\u043D\u0438 \u0443\u0441\u043B\u044B\u0448\u0430\u043B\u0438 \u0443\u0434\u0430\u0440."
    english: 'The night recognized your force. Move now: the living shadows heard
      the strike.'
    portuguese: 'A noite reconheceu a tua forca. Mexe-te: as sombras vivas ouviram
      o golpe.'
  - key: raw.return_gate.shoot_prompt
    russian: "\u041E\u0431\u0440\u0430\u0442\u043D\u044B\u0435 \u0432\u0440\u0430\u0442\u0430
      \u043E\u0442\u043A\u0440\u044B\u0442\u044B. \u0412\u044B\u0441\u0442\u0440\u0435\u043B\u0438
      \u0432 \u0440\u0430\u043C\u0443, \u0447\u0442\u043E\u0431\u044B \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
      \u043D\u0430\u0437\u0430\u0434."
    english: The return gate is open. Shoot the frame to return.
    portuguese: O portal de regresso esta aberto. Dispara contra a moldura para voltar.
  - key: raw.return_gate.shot
    russian: "\u0420\u0430\u043C\u0430 \u043F\u0440\u0438\u043D\u044F\u043B\u0430
      \u0443\u0434\u0430\u0440. \u041C\u0430\u0440\u0448\u0440\u0443\u0442 \u0441\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u043D\u0430\u0437\u0430\u0434."
    english: The frame takes the strike. The route folds backward.
    portuguese: A moldura aceitou o impacto. A rota dobra para tras.
  - key: speaker.price_altar
    russian: "\u0410\u041B\u0422\u0410\u0420\u042C \u0426\u0415\u041D\u042B"
    english: PRICE ALTAR
    portuguese: ALTAR DO PRECO
  - key: raw.gate.recovery.exterior
    russian: "\u041C\u0430\u0440\u0448\u0440\u0443\u0442 \u043D\u0435 \u0437\u0430\u043F\u0438\u0441\u0430\u043D.
      \u0422\u0435\u043B\u043E \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
      \u0442\u0440\u0435\u0442\u0438\u0439 \u043A\u0432\u0430\u0434\u0440\u0430\u0442.
      \u0412\u0440\u0430\u0442\u0430 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E\u0442
      \u0442\u0435\u0431\u044F \u0432 \u043D\u0430\u0447\u0430\u043B\u043E."
    english: The route is not recorded. Your body cannot hold the third square. The
      Gate returns you to the beginning.
    portuguese: A rota nao esta registada. O teu corpo nao aguenta o terceiro quadrado.
      Os Portoes devolvem-te ao inicio.
  - key: raw.gate.recovery.night
    russian: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0441\u043B\u0435\u0434 \u043D\u0435
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D. \u0412\u0440\u0430\u0442\u0430
      \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E\u0442 \u0442\u0435\u0431\u044F
      \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u043A\u0432\u0430\u0434\u0440\u0430\u0442."
    english: The second trace is unfinished. The Gate returns you to the second square.
    portuguese: O segundo rasto esta incompleto. Os Portoes devolvem-te ao segundo
      quadrado.
  - key: raw.price.prompt
    russian: "\u041F\u0440\u043E\u0445\u043E\u0434 \u0442\u0440\u0435\u0431\u0443\u0435\u0442
      \u043F\u043E\u0442\u0435\u0440\u0438. \u0412\u044B\u0431\u0435\u0440\u0438,
      \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0442
      \u0431\u044B\u0442\u044C \u0442\u0432\u043E\u0438\u043C."
    english: The passage demands a loss. Choose what will stop being yours.
    portuguese: A passagem exige uma perda. Escolhe o que deixara de ser teu.
  - key: raw.price.memory
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u043F\u0430\u043C\u044F\u0442\u044C"
    english: Give memory
    portuguese: Dar memoria
  - key: raw.price.name
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u0438\u043C\u044F"
    english: Give name
    portuguese: Dar nome
  - key: raw.price.joy
    russian: "\u041E\u0442\u0434\u0430\u0442\u044C \u0440\u0430\u0434\u043E\u0441\u0442\u044C"
    english: Give joy
    portuguese: Dar alegria
  - key: raw.price.refuse
    russian: "\u041E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F"
    english: Refuse
    portuguese: Recusar
  - key: raw.price.memory.accepted
    russian: "\u041F\u0430\u043C\u044F\u0442\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u0430.
      \u0421\u043B\u0435\u0434 \u043E \u0446\u0435\u043D\u0435 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
      \u043D\u0435\u043F\u043E\u043B\u043D\u044B\u043C."
    english: Memory accepted. The trace of the price remains incomplete.
    portuguese: Memoria aceite. O rasto do preco fica incompleto.
  - key: raw.price.name.accepted
    russian: "\u0418\u043C\u044F \u043F\u0440\u0438\u043D\u044F\u0442\u043E. \u041D\u0435
      \u043A\u0430\u0436\u0434\u044B\u0439 \u0437\u043E\u0432 \u0442\u0435\u043F\u0435\u0440\u044C
      \u0431\u0443\u0434\u0435\u0442 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
      \u0442\u0435\u0431\u044F."
    english: Name accepted. Not every call will find you now.
    portuguese: Nome aceite. Nem todo chamamento te encontrara agora.
  - key: raw.price.joy.accepted
    russian: "\u0420\u0430\u0434\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u0430.
      \u0423\u043B\u044B\u0431\u043A\u0430 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
      \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C
      \u043B\u0438\u0446\u0430."
    english: Joy accepted. A smile remains only a movement of the face.
    portuguese: Alegria aceite. O sorriso fica apenas como movimento do rosto.
  - key: raw.price.refused
    russian: "\u041E\u0442\u043A\u0430\u0437 \u0437\u0430\u043F\u0438\u0441\u0430\u043D.
      \u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0441\u0447\u0438\u0442\u0430\u0435\u0442
      \u044D\u0442\u043E \u043B\u0438\u0448\u043D\u0438\u043C \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C."
    english: Refusal recorded. The System marks it as unnecessary movement.
    portuguese: Recusa registada. O Sistema marca isso como movimento desnecessario.
  - key: raw.shadow_npc.unknown
    russian: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, \u0437\u0430\u0447\u0435\u043C
      \u0442\u044B \u0437\u0434\u0435\u0441\u044C."
    english: I do not know why you are here.
    portuguese: Nao sei porque estas aqui.
  - key: raw.shadow_npc.help_prompt
    russian: "\u0415\u0441\u043B\u0438 \u0442\u044B \u043F\u043E\u043C\u043E\u0436\u0435\u0448\u044C
      \u043C\u043D\u0435, \u043E\u043D\u0438 \u0443\u0432\u0438\u0434\u044F\u0442
      \u0442\u0435\u0431\u044F."
    english: If you help me, they will see you.
    portuguese: Se me ajudares, eles vao ver-te.
  - key: raw.shadow_npc.choice.help
    russian: "\u041F\u043E\u043C\u043E\u0447\u044C"
    english: Help
    portuguese: Ajudar
  - key: raw.shadow_npc.choice.ignore
    russian: "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C"
    english: Ignore
    portuguese: Ignorar
  - key: raw.shadow_npc.choice.push
    russian: "\u041E\u0442\u0442\u043E\u043B\u043A\u043D\u0443\u0442\u044C"
    english: Push away
    portuguese: Empurrar
  - key: raw.shadow_npc.help
    russian: "\u0422\u044B \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E
      \u043D\u0435 \u0434\u043B\u044F \u043C\u0435\u043D\u044F. \u041D\u043E \u044F
      \u0437\u0430\u043F\u043E\u043C\u043D\u044E \u043E\u0434\u0438\u043D \u0446\u0438\u043A\u043B."
    english: You did not do it for me. But I will remember one cycle.
    portuguese: Nao fizeste isto por mim. Mas vou lembrar um ciclo.
  - key: raw.shadow_npc.ignore
    russian: "\u0422\u0430\u043A \u043F\u0440\u043E\u0449\u0435. \u0422\u0430\u043A
      \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043B\u044E\u0431\u0438\u0442."
    english: That is easier. That is what the System likes.
    portuguese: Assim e mais facil. E disso que o Sistema gosta.
  - key: raw.shadow_npc.push
    russian: "\u041D\u043E\u0447\u044C \u0431\u044B\u0441\u0442\u0440\u043E \u0443\u0447\u0438\u0442
      \u0442\u0435\u0431\u044F \u0431\u044B\u0442\u044C \u0441\u0438\u043B\u044C\u043D\u044B\u043C."
    english: The night quickly teaches you to be strong.
    portuguese: A noite ensina depressa a seres forte.
