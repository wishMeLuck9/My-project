    russian: "\u0418\u041D\u0412\u0415\u0420\u0422\u0418\u0420\u041E\u0412\u0410\u0422\u042C
      \u041E\u0421\u042C Y"
    english: INVERT Y AXIS
    portuguese: INVERTER EIXO Y
  - key: settings.static_controls
    russian: "WASD - \u0431\u0435\u0433\nSHIFT - \u0445\u043E\u0434\u044C\u0431\u0430\nSPACE
      - \u043F\u0440\u044B\u0436\u043E\u043A / \u043A\u0430\u0440\u0430\u0431\u043A\u0430\u043D\u044C\u0435
      \u0443 \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u044F\nE
      - \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\nLMB
      - \u0430\u0442\u0430\u043A\u0430 \u043D\u043E\u0447\u044C\u044E\nESC - \u043F\u0430\u0443\u0437\u0430"
    english: 'WASD - run

      SHIFT - walk

      SPACE - jump / climb near an
      obstacle

      E - interact

      LMB - night attack

      ESC - pause'
    portuguese: "WASD - correr\nSHIFT - andar\nSPACE - saltar / trepar junto a obst\xE1culo\nE
      - interagir\nLMB - atacar \xE0 noite\nESC - pausa"
