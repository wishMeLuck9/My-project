  - key: menu.credits_text
    russian: "VIRUS9\n\n\u0421\u043E\u0431\u0440\u0430\u043D\u043E \u0437\u0430\u043D\u043E\u0432\u043E
      \u0434\u043B\u044F \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u0430."
    english: 'VIRUS9


      Rebuilt for the prototype.'
    portuguese: "VIRUS9\n\nReconstru\xEDdo para o prot\xF3tipo."
  - key: confirm.yes
    russian: "\u0414\u0410"
    english: YES
    portuguese: SIM
  - key: confirm.no
    russian: "\u041D\u0415\u0422"
    english: NO
    portuguese: "N\xC3O"
  - key: confirm.exit
    russian: "\u0412\u042B\u0419\u0422\u0418 \u0418\u0417 \u0418\u0413\u0420\u042B?"
    english: EXIT THE GAME?
    portuguese: SAIR DO JOGO?
  - key: confirm.main_menu
    russian: "\u0412\u0415\u0420\u041D\u0423\u0422\u042C\u0421\u042F \u0412 \u0413\u041B\u0410\u0412\u041D\u041E\u0415
      \u041C\u0415\u041D\u042E?\n\u041F\u0420\u041E\u0413\u0420\u0415\u0421\u0421
      \u0411\u0423\u0414\u0415\u0422 \u0410\u0412\u0422\u041E\u041C\u0410\u0422\u0418\u0427\u0415\u0421\u041A\u0418
      \u0421\u041E\u0425\u0420\u0410\u041D\u0415\u041D."
    english: 'RETURN TO MAIN MENU?

      PROGRESS WILL BE AUTOSAVED.'
    portuguese: 'VOLTAR AO MENU PRINCIPAL?

      O PROGRESSO SERA GUARDADO AUTOMATICAMENTE.'
